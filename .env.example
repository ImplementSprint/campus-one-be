PORT=4000
NODE_ENV=development

# Campus One uses backend-owned auth and Cloud SQL/PostgreSQL for runtime data.
DATABASE_URL=postgresql://campus_one:local-password@localhost:5432/campus_one
TENANT_REGISTRY_DATABASE_URL=postgresql://campus_one:local-password@localhost:5432/campus_one
IDENTITY_ACCESS_DATABASE_URL=postgresql://campus_one:local-password@localhost:5432/campus_one
CAMPUS_ONE_AUTH_SECRET=replace-with-at-least-16-random-characters

# Local development origins.
WEB_LMS_ORIGIN=http://localhost:3000
WEB_SCHOOL_ORIGIN=http://localhost:3001
MOBILE_DEV_ORIGIN=expo://localhost

# Optional live DB-backed smoke IDs. Leave blank for fast validation-only smoke.
CORE_SMOKE_PROFESSOR_ID=
CORE_SMOKE_CLASS_ID=
CORE_SMOKE_ALUMNI_ACTOR_UUID=
CORE_SMOKE_NOTIFICATION_PROFILE_ID=
