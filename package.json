{
  "name": "campus-one-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Campus One centralized NestJS backend monorepo",
  "scripts": {
    "start": "node dist/apps/gateway/src/main.js",
    "build": "tsc -p tsconfig.json",
    "test": "ts-node -r tsconfig-paths/register libs/tenants/src/tenant-resolution.middleware.test.ts && ts-node -r tsconfig-paths/register libs/tenants/src/public-school.service.test.ts",
    "contracts:generate": "node scripts/generate-contract-artifacts.mjs",
    "contracts:check": "node scripts/generate-contract-artifacts.mjs --check",
    "dev": "ts-node -r tsconfig-paths/register apps/gateway/src/main.ts",
    "start:dev": "npm run dev",
    "build:sources": "npm --workspace sources/main-be run build && npm --workspace sources/portal-be run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@supabase/supabase-js": "^2.49.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^16.0.0",
    "file-type": "^22.0.1",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tmp": "^0.2.5",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2",
    "webpack": "^5.106.2"
  }
}
