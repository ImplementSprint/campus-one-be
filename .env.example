PORT=4000
NODE_ENV=development

# Supabase service credentials are backend-only. Do not copy these into web or mobile repos.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key

# Prisma service database URLs are server-only. Do not copy these into web or mobile repos.
TENANT_REGISTRY_DATABASE_URL=postgresql://user:password@localhost:5432/tenant_registry?schema=public
IDENTITY_ACCESS_DATABASE_URL=postgresql://user:password@localhost:5432/identity_access?schema=public
ACADEMICS_DATABASE_URL=postgresql://user:password@localhost:5432/academics?schema=public
ADMISSIONS_DATABASE_URL=postgresql://user:password@localhost:5432/admissions?schema=public
REGISTRAR_DATABASE_URL=postgresql://user:password@localhost:5432/registrar?schema=public
ALUMNI_DATABASE_URL=postgresql://user:password@localhost:5432/alumni?schema=public
BILLING_DATABASE_URL=postgresql://user:password@localhost:5432/billing?schema=public
NOTIFICATIONS_AUDIT_DATABASE_URL=postgresql://user:password@localhost:5432/notifications_audit?schema=public

# Application domains.
APP_BASE_DOMAIN=itsandbox.site
SCHOOL_PORTAL_BASE_DOMAIN=itsandbox.site
PUBLIC_LMS_URL=http://localhost:3000

# Preferred CORS config. Comma-separated.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Legacy local development origins. Runtime config still reads these as fallback.
WEB_LMS_ORIGIN=http://localhost:3000
WEB_SCHOOL_ORIGIN=http://localhost:3001
MOBILE_DEV_ORIGIN=expo://localhost
